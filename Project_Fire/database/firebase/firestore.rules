rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Detections collection
    match /detections/{detection} {
      allow read: if true;  // Anyone can read detections
      allow create: if request.auth != null;  // Only authenticated users can create
      allow update: if request.auth != null;  // Only authenticated users can update
      allow delete: if false;  // No one can delete
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Notifications collection
    // Writes are done exclusively by the backend via Admin SDK (bypasses rules).
    // Clients are read-only to prevent abuse/spoofing.
    match /notifications/{notification} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}