FIREBASE_CREDENTIALS_JSON=
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Supabase (Image Storage)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_BUCKET_NAME=detections

# Twilio (SMS Alerts)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email Alerts (SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=

# FCM (Push Notifications)
FCM_SERVER_KEY=

# Security
JWT_SECRET_KEY=

# Google Maps
GOOGLE_MAPS_API_KEY=

# n8n Automation
N8N_PASSWORD=

# Emergency Contacts
EMERGENCY_PHONE_NUMBERS=

# App
DEBUG=False
ENVIRONMENT=development

# AI / LLM
GROQ_API_KEY=
GEMINI_API_KEY=

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
